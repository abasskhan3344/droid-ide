{
  "name": "android-ide-web",
  "version": "1.0.0",
  "description": "A complete, fully working Android IDE web application like Android Studio.",
  "main": "dist/server/index.js",
  "scripts": {
    "setup": "echo \"Setup script will be implemented later.\"",
    "dev:server": "nodemon --watch src/server --ext ts --exec ts-node src/server/index.ts",
    "dev:client": "vite --config src/renderer/vite.config.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "tsc --project src/server/tsconfig.json",
    "build:client": "vite build --config src/renderer/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "postinstall": "npm run build:server"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@monaco-editor/react": "^4.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "isomorphic-git": "^1.25.0",
    "monaco-editor": "^0.48.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.17.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@isomorphic-git/http-backend": "^1.2.0",
    "@isomorphic-git/lightning-fs": "^4.6.0",
    "@types/concurrently": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.12",
    "@types/node-pty": "^1.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.5.10",
    "@types/xterm": "^3.12.3",
    "@types/xterm-addon-fit": "^0.8.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}